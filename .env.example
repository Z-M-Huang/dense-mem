# Dense Memory API Server Configuration

# =============================================================================
# Server Configuration
# =============================================================================

# HTTP server bind address (default: ":8080")
HTTP_ADDR=:8080

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================

# PostgreSQL connection string (required)
# Format: postgres://user:password@host:port/dbname?sslmode=disable
POSTGRES_DSN=postgres://user:password@localhost:5432/densemem?sslmode=disable

# =============================================================================
# Graph Database Configuration (Neo4j)
# =============================================================================

# Neo4j connection URI (required)
# Format: bolt://host:port or neo4j://host:port
NEO4J_URI=bolt://localhost:7687

# Neo4j authentication (required)
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Neo4j database name (optional, uses default if not set)
NEO4J_DATABASE=

# =============================================================================
# Redis Configuration (optional for single-node, required for multi-instance)
# =============================================================================

# Redis server address (optional for single-node)
REDIS_ADDR=localhost:6379

# Redis authentication (optional)
REDIS_PASSWORD=

# Redis database number (default: 0)
REDIS_DB=0

# =============================================================================
# Rate Limiting Configuration
# =============================================================================

# General API rate limit per minute (default: 100)
RATE_LIMIT_PER_MINUTE=100

# =============================================================================
# Server-Sent Events (SSE) Configuration
# =============================================================================

# Heartbeat interval in seconds (default: 30)
SSE_HEARTBEAT_SECONDS=30

# Maximum duration of an SSE stream in seconds (default: 300 = 5 minutes)
SSE_MAX_DURATION_SECONDS=300

# Maximum concurrent SSE streams per client (default: 10)
SSE_MAX_CONCURRENT_STREAMS=10

# =============================================================================
# Embedding Configuration
# =============================================================================

# Vector embedding dimensions (default: 1536)
# Common values: 1536 (OpenAI), 768 (BERT), 384 (all-MiniLM)
EMBEDDING_DIMENSIONS=1536

# AI provider base URL (required for server startup)
AI_API_URL=https://api.openai.com/v1

# AI provider API key (required for server startup)
AI_API_KEY=

# Embedding model name (required for server startup)
AI_API_EMBEDDING_MODEL=text-embedding-3-small

# Embedding dimensions must match the provider/model output (required for server startup)
AI_API_EMBEDDING_DIMENSIONS=1536

# Embedding request timeout in seconds (default: 30)
AI_API_EMBEDDING_TIMEOUT_SECONDS=30
