# Dense Memory API Server Configuration

# =============================================================================
# Logging Configuration
# =============================================================================

# Logging level. Set to debug for verbose logs.
LOG_LEVEL=info

# =============================================================================
# Local Control Portal Configuration
# =============================================================================

# Required for the local profile/API-key management portal.
# Send as Bearer or X-Control-Portal-Token.
CONTROL_PORTAL_TOKEN=

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================

# Docker compose database credentials. The server image builds POSTGRES_DSN
# from these values at container startup when POSTGRES_DSN is not set.
POSTGRES_USER=densemem
POSTGRES_PASSWORD=
POSTGRES_DB=densemem
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable

# Non-compose deployments may set POSTGRES_DSN directly instead.
POSTGRES_DSN=

# =============================================================================
# Graph Database Configuration (Neo4j)
# =============================================================================

# Neo4j connection URI (required)
# Format: bolt://host:port or neo4j://host:port
NEO4J_URI=bolt://neo4j:7687

# Neo4j authentication (required)
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Neo4j database name (optional, uses default if not set)
NEO4J_DATABASE=

# Host ports used by docker-compose.example.yml for local/dev access.
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# =============================================================================
# Redis Configuration (optional for single-node, required for multi-instance)
# =============================================================================

# Redis server address. Leave blank for single-node in-memory mode.
# Set to 127.0.0.1:6379 when running the compose redis profile.
REDIS_ADDR=

# Host port used by docker-compose.example.yml when Redis is enabled.
REDIS_PORT=6379

# Redis authentication (optional)
REDIS_PASSWORD=

# Redis database number (default: 0)
REDIS_DB=0

# =============================================================================
# Rate Limiting Configuration
# =============================================================================

# General API rate limit per minute (default: 100)
RATE_LIMIT_PER_MINUTE=100

# =============================================================================
# Server-Sent Events (SSE) Configuration
# =============================================================================

# Heartbeat interval in seconds (default: 30)
SSE_HEARTBEAT_SECONDS=30

# Maximum duration of an SSE stream in seconds (default: 300 = 5 minutes)
SSE_MAX_DURATION_SECONDS=300

# Maximum concurrent SSE streams per client (default: 10)
SSE_MAX_CONCURRENT_STREAMS=10

# =============================================================================
# Embedding Configuration
# =============================================================================

# AI provider base URL (required for server startup)
AI_API_URL=https://api.openai.com/v1

# AI provider API key (required for server startup)
AI_API_KEY=

# Embedding model name (required for server startup)
AI_API_EMBEDDING_MODEL=text-embedding-3-small

# Embedding dimensions must match the provider/model output (required for server startup)
AI_API_EMBEDDING_DIMENSIONS=1536

# Embedding request timeout in seconds (default: 30)
AI_API_EMBEDDING_TIMEOUT_SECONDS=30

# Verifier provider base URL for claim/evidence checks.
# Leave blank to reuse AI_API_URL.
AI_VERIFIER_API_URL=

# Verifier provider API key.
# Leave blank to reuse AI_API_KEY only when AI_VERIFIER_API_URL is also blank.
AI_VERIFIER_API_KEY=

# Chat/completions model used to verify claims before promotion.
AI_VERIFIER_MODEL=gpt-4o-mini

# Verifier request timeout in seconds (default: 60)
AI_VERIFIER_TIMEOUT_SECONDS=60
