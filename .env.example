# Dense Memory API Server Configuration

# =============================================================================
# Server Configuration
# =============================================================================

# HTTP server bind address (default: ":8080")
HTTP_ADDR=:8080

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================

# PostgreSQL connection string (required)
# Format: postgres://user:password@host:port/dbname?sslmode=disable
POSTGRES_DSN=postgres://user:password@localhost:5432/densemem?sslmode=disable

# =============================================================================
# Graph Database Configuration (Neo4j)
# =============================================================================

# Neo4j connection URI (required)
# Format: bolt://host:port or neo4j://host:port
NEO4J_URI=bolt://localhost:7687

# Neo4j authentication (required)
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Neo4j database name (optional, uses default if not set)
NEO4J_DATABASE=

# =============================================================================
# Cache Configuration (Redis)
# =============================================================================

# Redis server address (required)
REDIS_ADDR=localhost:6379

# Redis authentication (optional)
REDIS_PASSWORD=

# Redis database number (default: 0)
REDIS_DB=0

# =============================================================================
# Security Configuration
# =============================================================================

# Bootstrap admin API key for initial setup (optional)
BOOTSTRAP_ADMIN_KEY=

# Argon2id password hashing parameters
# Memory in KB (default: 65536 = 64MB)
ARGON_MEMORY_KB=65536

# Number of iterations (default: 1)
ARGON_TIME=1

# Number of parallel threads (default: 4)
ARGON_THREADS=4

# =============================================================================
# Rate Limiting Configuration
# =============================================================================

# General API rate limit per minute (default: 100)
RATE_LIMIT_PER_MINUTE=100

# Admin API rate limit per minute (default: 1000)
ADMIN_RATE_LIMIT_PER_MINUTE=1000

# =============================================================================
# Server-Sent Events (SSE) Configuration
# =============================================================================

# Heartbeat interval in seconds (default: 30)
SSE_HEARTBEAT_SECONDS=30

# Maximum duration of an SSE stream in seconds (default: 300 = 5 minutes)
SSE_MAX_DURATION_SECONDS=300

# Maximum concurrent SSE streams per client (default: 10)
SSE_MAX_CONCURRENT_STREAMS=10

# =============================================================================
# Admin Query Configuration
# =============================================================================

# Query timeout for admin endpoints in seconds (default: 30)
ADMIN_QUERY_TIMEOUT_SECONDS=30

# Maximum rows returned by admin queries (default: 1000)
ADMIN_QUERY_ROW_CAP=1000

# =============================================================================
# Embedding Configuration
# =============================================================================

# Vector embedding dimensions (default: 1536)
# Common values: 1536 (OpenAI), 768 (BERT), 384 (all-MiniLM)
EMBEDDING_DIMENSIONS=1536
